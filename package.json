{
	"name": "@kyrnox/sentry-monorepo",
	"version": "0.1.0",
	"private": true,
	"description": "Kyrnox SENTRY — open-source SDK, tools, and CLI for IAM-governed coding agents and signed policy bundles.",
	"type": "module",
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"scripts": {
		"build": "npm run build --workspaces --if-present",
		"clean": "npm run clean --workspaces --if-present && rm -rf dist .turbo coverage",
		"dev": "npm run dev --workspace @kyrnox/sentry-cli",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "npm run typecheck --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"test:unit": "vitest run --workspace vitest.workspace.ts",
		"social-preview": "node scripts/render-social-preview.mjs"
	},
	"engines": {
		"node": ">=22",
		"npm": ">=10"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@resvg/resvg-js": "^2.6.2",
		"@types/node": "^22.10.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	},
	"packageManager": "npm@10.9.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/kyrnox-ai/kyrnox-sentry.git"
	},
	"homepage": "https://github.com/kyrnox-ai/kyrnox-sentry",
	"license": "Apache-2.0"
}
