{
	"name": "@kyrnox/sentry-cli",
	"version": "1.0.0-alpha.1",
	"description": "Kyrnox SENTRY command-line interface for the open-source SDK and tools.",
	"type": "module",
	"bin": {
		"kyrnox-sentry": "./dist/main.js"
	},
	"main": "dist/main.js",
	"types": "dist/main.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"clean": "rm -rf dist tsconfig.tsbuildinfo",
		"dev": "tsx src/main.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts"
	},
	"dependencies": {
		"@kyrnox/sentry-sdk": "1.0.0-alpha.1",
		"@kyrnox/sentry-tools": "1.0.0-alpha.1",
		"chalk": "^5.3.0",
		"cli-boxes": "^4.0.0",
		"commander": "^12.1.0",
		"figlet": "^1.7.0",
		"gradient-string": "^3.0.0",
		"ink": "^5.0.1",
		"react": "^18.3.1",
		"strip-ansi": "^7.1.0"
	},
	"devDependencies": {
		"@types/figlet": "^1.5.0",
		"@types/gradient-string": "^1.1.6",
		"@types/react": "^18.3.12",
		"ink-testing-library": "^4.0.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/kyrnox-ai/kyrnox-sentry.git",
		"directory": "packages/sentry-cli"
	},
	"homepage": "https://github.com/kyrnox-ai/kyrnox-sentry/tree/main/packages/sentry-cli",
	"license": "Apache-2.0",
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
