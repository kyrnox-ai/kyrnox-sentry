{
  "name": "@kyrnox/shared",
  "version": "0.1.0",
  "description": "Shared utilities, types, schemas, and enterprise contracts for Kyrnox.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {"zod":"^3.24.1","nanoid":"^5.0.9"},
  "devDependencies": {}
}
