{
	"name": "@kyrnox/sentry-demo",
	"version": "0.0.0",
	"private": true,
	"description": "Browser-rendered SENTRY ops console: mirrors the kyrnox-sentry CLI panel grid and exercises the public evaluator against a static bundle.",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc -p tsconfig.json --noEmit && vite build",
		"preview": "vite preview",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run --config vitest.config.ts"
	},
	"dependencies": {
		"@fontsource/geist-mono": "^5.1.0",
		"@fontsource/jetbrains-mono": "^5.1.0",
		"@fontsource/space-mono": "^5.1.0",
		"@kyrnox/sentry-sdk": "*",
		"react": "^18.3.1",
		"react-dom": "^18.3.1"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.1.0",
		"@types/react": "^18.3.12",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react": "^4.3.4",
		"jsdom": "^25.0.1",
		"typescript": "^5.7.2",
		"vite": "^5.4.11",
		"vitest": "^2.1.8"
	},
	"license": "Apache-2.0"
}
